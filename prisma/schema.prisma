// Prisma schema — PT Wana Samudra Persada HR & Payroll Outsourcing
//
// Datasource is PostgreSQL (Neon, provisioned via Vercel Marketplace).
// String fields are used instead of native `enum` in a few places purely
// for continuity with the earlier SQLite schema — fine as-is on Postgres,
// optionally convertible to real `enum` types later if desired.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Auth & access control ──────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  // Separate login ID (e.g. "hrwana1"), distinct from email — either one
  // can be used to log in. Nullable so pre-existing accounts (which only
  // ever had email) keep working unchanged.
  username      String?  @unique
  passwordHash  String
  name          String
  role          String   // ADMIN | HR | FINANCE | SUPERVISOR | EMPLOYEE
  active        Boolean  @default(true)
  // Explicit page allowlist (nav hrefs) for this user. Empty = fall back
  // to the role's default pages; non-empty overrides the role default.
  pageAccess    String[] @default([])
  totpSecret    String?  // base32 — set once 2FA setup starts, kept even while unconfirmed
  totpEnabled   Boolean  @default(false)
  employeeId    String?  @unique
  employee      Employee? @relation(fields: [employeeId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  auditLogs     AuditLog[]
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String   // e.g. "employee.update", "payroll.pay", "invoice.markPaid"
  entity    String   // e.g. "Employee", "Invoice"
  entityId  String?
  detail    String?  // JSON string with before/after or extra context
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
}

// ── Org structure ──────────────────────────────────────────────────────

model Site {
  id           String        @id @default(cuid())
  name         String
  address      String
  supervisor   String
  umr          Int           @default(0)
  employees    Employee[]
  payrollRates PayrollRate[]
  createdAt    DateTime      @default(now())
}

model Position {
  id          String     @id @default(cuid())
  name        String     @unique
  salaryType  String     // "bulanan" | "harian"
  baseSalary  Int
  employees   Employee[]
}

model Client {
  id             String        @id @default(cuid())
  name           String
  pic            String
  picPhone       String?
  address        String?
  contractStart  DateTime
  contractEnd    DateTime
  feeType        String        // "percent" | "flat"
  feeValue       Int
  employees      Employee[]
  invoicesBj     InvoiceBj[]
  invoices       Invoice[]
  createdAt      DateTime      @default(now())
}

// ── Employees & lifecycle ──────────────────────────────────────────────

model Employee {
  id              String   @id @default(cuid())
  empCode         String   @unique // e.g. EMP-0001
  name            String
  siteId          String
  site            Site     @relation(fields: [siteId], references: [id])
  positionId      String
  position        Position @relation(fields: [positionId], references: [id])
  clientId        String?
  client          Client?  @relation(fields: [clientId], references: [id])
  hireDate        DateTime
  contractType    String   // "PKWT" | "PKWTT"
  contractEnd     DateTime?
  cutiKuota       Int      @default(12)
  kasbon          Int      @default(0) // total outstanding balance
  kasbonCicilan   Int      @default(1) // over how many months to deduct it (1 = full amount at once)
  status          String   @default("aktif") // "aktif" | "resign"
  thrPaid         Boolean  @default(false)
  thrOverride     Int?
  // null = use the standard formula (computeBpjsKesehatan / computeBpjsKetenagakerjaanKaryawan);
  // set = deduct this exact amount instead, for cases the formula doesn't match reality.
  bpjsKesehatanOverride       Int?
  bpjsKetenagakerjaanOverride Int?
  overtimeHours   Int      @default(0)
  workDays        Int      @default(22)
  presentDays     Int      @default(22)
  leaveDays       Int      @default(0)
  attStatus       String   @default("Hadir") // today's status: Hadir | Izin | Alpha
  checkIn         String?
  checkOut        String?

  ktpNumber       String?
  phone           String?
  contractNumber  String?  // "No PKWT" — contract doc reference, distinct from contractType
  education       String?
  bankName        String?
  bankAccount     String?
  birthPlace      String?
  birthDate       DateTime?
  address         String?
  gender          String?  // "Pria" | "Wanita"
  religion        String?  // "Islam" | "Kristen" | "Katolik" | "Hindu" | "Buddha" | "Konghucu" | "Lainnya"

  salaryComponents SalaryComponent[]
  leaveRequests     LeaveRequest[]
  assignments       Assignment[]
  attendance        AttendanceRecord[]
  certificates      Certificate[]
  payrollEntries    PayrollEntry[]
  allowancePayments AllowancePayment[]
  overtimeDays      OvertimeDay[]
  user              User?

  resignDate      DateTime?
  resignReason    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([siteId])
  @@index([clientId])
  @@index([status])
}

model SalaryComponent {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  name       String   // "Gaji Pokok", "Tunjangan Transport", ...
  amount     Int

  @@index([employeeId])
}

model Certificate {
  id         String    @id @default(cuid())
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  name       String
  validFrom  DateTime?
  validUntil DateTime?

  @@index([employeeId])
}

// Configurable flat-rate deductions/overtime rates per period, optionally
// overridden per site — siteId null is the default/fallback rate applied
// to every site that doesn't have its own override for that period.
model PayrollRate {
  id                String   @id @default(cuid())
  period            String   // "2026-06"
  siteId            String?
  site              Site?    @relation(fields: [siteId], references: [id], onDelete: SetNull)
  izinRate          Int      @default(0)
  alphaRate         Int      @default(0)
  terlambatRate     Int      @default(0)
  lemburRegulerRate Int      @default(0)
  lemburMerahRate   Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([period, siteId])
  @@index([period])
}

// Manually-entered per-employee-per-period overtime counts + allowance —
// unlike Employee.overtimeHours (a single live/current value), this is
// scoped to a specific payroll period.
model PayrollEntry {
  id            String   @id @default(cuid())
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  period        String
  allowance     Int      @default(0) // Rp
  note          String?
  // null = compute from attendance count × PayrollRate as usual; set = deduct
  // this exact amount instead, for this employee in this period only.
  potonganIzinOverride      Int?
  potonganAlphaOverride     Int?
  potonganTerlambatOverride Int?
  potonganAbsensiOverride   Int? // no-rate branch's proportional potongan absensi
  // Rate lembur beda-beda per orang di dunia nyata — kosongkan untuk hitung
  // otomatis dari jumlah OvertimeDay, isi untuk pakai angka manual.
  lemburOverride            Int?
  gajiPokokOverride         Int?
  penugasanTambahanOverride Int? // ganti total dari jumlah Assignment.cost
  kasbonOverride            Int? // ganti potongan kasbon bulan ini
  // Set together when the monthly payroll run for this employee/period is
  // paid out via "Bayar Gaji" — paid stays false until then so re-running
  // payment for a site skips whoever's already been paid instead of
  // double-posting to Kas.
  paid              Boolean  @default(false)
  paidTransactionId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([employeeId, period])
  @@index([employeeId])
}

// One row per overtime day actually worked, instead of a single manually
// typed count — HR records the specific dates (mis. tanggal merah 13, 15),
// and computeMonthlyPayroll counts them per type to price the lembur line.
model OvertimeDay {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  period     String   // "2026-06" — derived from date, kept for cheap querying
  date       DateTime
  type       String   // "reguler" | "merah"
  note       String?
  createdAt  DateTime @default(now())

  @@index([employeeId, period])
}

// Off-cycle bonus/incentive payment — deliberately separate from
// PayrollEntry.allowance (which is folded into the monthly gaji-tgl-1 run):
// this is payable on any date, its own cash Transaction, own history.
model AllowancePayment {
  id            String   @id @default(cuid())
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date          DateTime
  amount        Int
  desc          String?
  transactionId String
  createdById   String?
  createdAt     DateTime @default(now())

  @@index([employeeId])
}

model AttendanceRecord {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date       DateTime
  status     String   // "Hadir" | "Izin" | "Alpha" | "Hari Libur"
  checkIn    String?
  checkOut   String?
  scheduledCheckIn  String?
  scheduledCheckOut String?
  lateMin    Int      @default(0)
  overtimeHours Int   @default(0)
  location   String?
  createdAt  DateTime @default(now())

  @@unique([employeeId, date])
  @@index([date])
}

model LeaveRequest {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type       String   // "Cuti Tahunan" | "Sakit" | "Melahirkan" | "Lainnya"
  startDate  DateTime
  endDate    DateTime
  reason     String
  status     String   @default("menunggu") // "menunggu" | "disetujui" | "ditolak"
  createdAt  DateTime @default(now())

  @@index([employeeId])
  @@index([status])
}

model Assignment {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  title      String
  mandays    Int
  cost       Int
  status     String   @default("berjalan") // "berjalan" | "selesai"
  // Which payslip period this cost belongs to (e.g. "2026-07") — nullable
  // for rows created before this field existed. Only "selesai" assignments
  // with a period actually show up on that period's payslip / Kas total.
  period     String?
  createdAt  DateTime @default(now())

  @@index([employeeId])
}

model Candidate {
  id            String   @id @default(cuid())
  name          String
  position      String
  appliedDate   DateTime
  status        String   @default("lamaran") // lamaran | interview | diterima | aktif | ditolak
  hiredEmployeeId String?
  createdAt     DateTime @default(now())
}

// ── Client billing ──────────────────────────────────────────────────────

model Invoice {
  // Monthly outsourcing-fee invoice, one per client per period.
  id           String   @id @default(cuid())
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id])
  invoiceNo    String   @unique
  period       String   // "2026-07"
  status       String   @default("draft") // draft | terkirim | lunas
  dueDate      DateTime?
  docHandoverDate DateTime? // tanggal dokumen invoice fisik diserahkan ke klien
  gajiTotal    Int
  feeTotal     Int
  total        Int
  sentAt       DateTime?
  paidAt       DateTime?
  createdAt    DateTime @default(now())

  @@unique([clientId, period])
  @@index([status])
}

model InvoiceBj {
  id          String        @id @default(cuid())
  invoiceNo   String        @unique
  clientId    String
  client      Client        @relation(fields: [clientId], references: [id])
  date        DateTime
  dueDate     DateTime
  docHandoverDate DateTime? // tanggal dokumen invoice fisik diserahkan ke klien
  withPpn     Boolean       @default(true)
  jobTitle    String?       // judul pekerjaan/proyek yang ditagihkan
  discountDesc    String?   // keterangan diskon, mis. "Diskon pelanggan lama"
  discountPercent Int       @default(0) // 0-100, persen dari subtotal
  signerName  String?       // nama penandatangan pihak WSP di invoice ini
  status      String        @default("draft") // draft | terkirim | lunas
  items       InvoiceBjItem[]
  createdAt   DateTime      @default(now())

  @@index([clientId])
  @@index([status])
}

model InvoiceBjItem {
  id          String    @id @default(cuid())
  invoiceId   String
  invoice     InvoiceBj @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  desc        String
  qty         Int
  price       Int
}

// ── Finance: COA, cash accounts, transactions, payables ────────────────

model Account {
  id       String  @id @default(cuid())
  code     String  @unique
  name     String
  type     String  // "masuk" | "keluar"
  budget   Int?    // monthly budget, for "keluar" accounts

  transactions Transaction[]
}

model CashAccount {
  id       String  @id @default(cuid())
  name     String
  opening  Int     @default(0)
  kind     String  @default("besar") // "kecil" | "besar" — memisahkan kas kecil (petty cash) dari kas besar (rekening bank/operasional)

  transactions Transaction[]
}

model Transaction {
  id            String      @id @default(cuid())
  date          DateTime
  accountCoaId  String
  account       Account     @relation(fields: [accountCoaId], references: [id])
  cashAccountId String
  cashAccount   CashAccount @relation(fields: [cashAccountId], references: [id])
  desc          String
  amount        Int
  type          String      // "masuk" | "keluar"
  isTransfer    Boolean     @default(false)
  attachmentUrl String?
  createdById   String?
  createdAt     DateTime    @default(now())

  @@index([date])
  @@index([accountCoaId])
  @@index([cashAccountId])
}

model Payable {
  id         String   @id @default(cuid())
  vendorName String
  desc       String
  amount     Int
  dueDate    DateTime
  status     String   @default("belum") // "belum" | "lunas"
  paidAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([status])
}

model ClosedPeriod {
  id       String   @id @default(cuid())
  period   String   @unique // "2026-07"
  closedAt DateTime @default(now())
  closedBy String?
}

// ── Gudang (inventory) ──────────────────────────────────────────────────

model InventoryItem {
  id        String   @id @default(cuid())
  name      String
  unit      String   // satuan, mis. "unit", "pcs", "set"
  qty       Int      @default(0) // stok saat ini
  price     Int      // harga satuan sekarang (Rp) — dipakai sebagai default saat permintaan baru
  category  String?
  requests  InventoryRequest[]
  createdAt DateTime @default(now())

  @@index([name])
}

// Satu baris = satu kali barang diambil/diminta dari gudang. itemName dan
// unitPrice di-snapshot pada saat pengambilan (bukan diambil live dari
// InventoryItem) supaya buktinya tetap akurat meski harga/nama barang di
// katalog berubah belakangan — sama seperti Transaction.amount yang juga
// tidak pernah dihitung ulang dari sumbernya.
model InventoryRequest {
  id            String        @id @default(cuid())
  itemId        String
  item          InventoryItem @relation(fields: [itemId], references: [id])
  itemName      String
  qty           Int
  unitPrice     Int
  requesterName String
  department    String?
  note          String?
  date          DateTime      @default(now())
  transactionId String?
  createdById   String?
  createdAt     DateTime      @default(now())

  @@index([itemId])
  @@index([date])
}
